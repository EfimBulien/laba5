<Page x:Class="laba5.OrderCheckPage"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:laba5"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="900"
      Title="OrderCheckPage">
    <Grid Background="{DynamicResource MaterialDesignPaper}">
        <ScrollViewer>
            <StackPanel VerticalAlignment="Top" Margin="15">

                <!-- Секция создания заказа -->
                <materialDesign:Card Margin="0,0,0,15" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Создать новый заказ" 
                                   Margin="0,0,0,15" 
                                   FontWeight="Bold"
                                   FontSize="16"
                                   Foreground="{DynamicResource MaterialDesignPrimaryHueDarkBrush}"/>

                        <ComboBox x:Name="CustomerComboBox" 
                                  materialDesign:HintAssist.Hint="Покупатель"
                                  Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                  Margin="0,5"/>

                        <ComboBox x:Name="EmployeeComboBox" 
                                  materialDesign:HintAssist.Hint="Сотрудник"
                                  Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                  Margin="0,5"/>

                        <TextBox x:Name="OrderDateBox" 
                                 materialDesign:HintAssist.Hint="Дата заказа (ГГГГ-ММ-ДД)"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                 Margin="0,5"/>

                        <TextBox x:Name="OrderTimeBox" 
                                 materialDesign:HintAssist.Hint="Время заказа (ЧЧ:ММ)"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                 Margin="0,5"/>

                        <ComboBox x:Name="PaymentMethodComboBox" 
                                  materialDesign:HintAssist.Hint="Способ оплаты"
                                  Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                  Margin="0,5"/>

                        <TextBlock Text="Выберите автомобили:"
                                   Margin="0,15,0,5"
                                   FontWeight="Bold"/>

                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>

                            <ComboBox x:Name="CarComboBox" 
                                      materialDesign:HintAssist.Hint="Автомобиль"
                                      Grid.Column="0"
                                      Margin="0,0,5,0"/>

                            <TextBox x:Name="CarQuantityBox" 
                                     materialDesign:HintAssist.Hint="Кол-во"
                                     Grid.Column="1"
                                     Margin="5,0,5,0"/>

                            <Button x:Name="AddCarButton" 
                                    Content="Добавить" 
                                    Click="AddCarButton_Click"
                                    Grid.Column="2"
                                    Margin="5,0,0,0"/>
                        </Grid>

                        <TextBlock Text="Машины в заказе:"
                                   Margin="0,15,0,5"
                                   FontWeight="Bold"/>

                        <DataGrid x:Name="OrderCarsDataGrid"
                                  Margin="0,5"
                                  Height="150"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Модель" Binding="{Binding Model}" Width="*" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat=C}" Width="100" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="60"/>
                                <DataGridTextColumn Header="Сумма" Binding="{Binding Total, StringFormat=C}" Width="100" IsReadOnly="True"/>
                                <DataGridTemplateColumn Header="Удалить" Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Удалить" Click="RemoveCarButton_Click" Padding="5"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10">
                            <TextBlock Text="Общая сумма: " FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock x:Name="TotalPriceTextBlock" 
                                       Text="0.00 руб." 
                                       FontWeight="Bold" 
                                       FontSize="14"
                                       Foreground="{DynamicResource MaterialDesignPrimaryHueDarkBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <Button x:Name="CreateOrderButton" 
                                Content="Создать заказ" 
                                Click="CreateOrderButton_Click" 
                                Foreground="White"
                                Margin="0,15,0,0"/>
                    </StackPanel>
                </materialDesign:Card>

                <materialDesign:Card Margin="0,0,0,15" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Редактировать/Удалить заказ" 
                                   Margin="0,0,0,15" 
                                   FontWeight="Bold"
                                   FontSize="16"
                                   Foreground="{DynamicResource MaterialDesignPrimaryHueDarkBrush}"/>

                        <TextBox x:Name="EditOrderCheckIDBox" 
                                 materialDesign:HintAssist.Hint="ID заказа"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                 Margin="0,5"/>

                        <ComboBox x:Name="EditCustomerComboBox" 
                                  materialDesign:HintAssist.Hint="Новый покупатель"
                                  Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                  Margin="0,5"/>

                        <ComboBox x:Name="EditEmployeeComboBox" 
                                  materialDesign:HintAssist.Hint="Новый сотрудник"
                                  Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                  Margin="0,5"/>

                        <TextBox x:Name="EditOrderDateBox" 
                                 materialDesign:HintAssist.Hint="Новая дата (ГГГГ-ММ-ДД)"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                 Margin="0,5"/>

                        <TextBox x:Name="EditOrderTimeBox" 
                                 materialDesign:HintAssist.Hint="Новое время (ЧЧ:ММ)"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                 Margin="0,5"/>

                        <ComboBox x:Name="EditPaymentMethodComboBox" 
                                  materialDesign:HintAssist.Hint="Новый способ оплаты"
                                  Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                  Margin="0,5"/>

                        <TextBox x:Name="EditPaidAmountBox" 
                                 materialDesign:HintAssist.Hint="Новая сумма"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                 Margin="0,5"/>

                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Button x:Name="EditOrderButton" 
                                    Content="Изменить" 
                                    Click="EditOrderButton_Click"
                                    Foreground="White"
                                    Width="120"
                                    Margin="0,0,10,0"/>
                            <Button x:Name="DeleteOrderButton" 
                                    Content="Удалить" 
                                    Click="DeleteOrderButton_Click" 
                                    Foreground="White"
                                    Width="120"/>
                        </StackPanel>
                    </StackPanel>
                </materialDesign:Card>

                <materialDesign:Card Margin="0,0,0,15" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Просмотр заказа" 
                                   Margin="0,0,0,15" 
                                   FontWeight="Bold"
                                   FontSize="16"
                                   Foreground="{DynamicResource MaterialDesignPrimaryHueDarkBrush}"/>

                        <TextBox x:Name="ViewOrderIDBox" 
                                 materialDesign:HintAssist.Hint="ID заказа для просмотра"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                 Margin="0,5"/>

                        <Button x:Name="ViewOrderButton" 
                                Content="Показать автомобили" 
                                Click="ViewOrderButton_Click" 
                                Margin="0,5"/>

                        <ListBox x:Name="OrderCarsListBox" 
                                 Height="150"
                                 Margin="0,10"
                                 Style="{StaticResource MaterialDesignListBox}"/>

                        <TextBlock x:Name="TotalAmountText" 
                                   FontWeight="Bold"
                                   Margin="0,5"
                                   Foreground="{DynamicResource MaterialDesignPrimaryHueDarkBrush}"
                                   FontSize="14"/>
                    </StackPanel>
                </materialDesign:Card>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>