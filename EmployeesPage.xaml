<Page x:Class="laba5.EmployeesPage"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:laba5"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="EmployeesPage">
    <Grid>
        <StackPanel VerticalAlignment="Bottom">
            <TextBlock Text="Добавить сотрудника:" 
                       Margin="5" 
                       FontWeight="Bold"
                       Foreground="Gray"/>
            <TextBox x:Name="FirstnameBox" 
                     materialDesign:HintAssist.Hint="Имя" 
                     Margin="5"/>
            <TextBox x:Name="SurnameBox" 
                     materialDesign:HintAssist.Hint="Фамилия" 
                     Margin="5"/>
            <TextBox x:Name="PatronymicBox" 
                     materialDesign:HintAssist.Hint="Отчество" 
                     Margin="5"/>
            <TextBox x:Name="PostBox" 
                     materialDesign:HintAssist.Hint="Должность" 
                     Margin="5"/>
            <ComboBox x:Name="AccountComboBox" 
                      materialDesign:HintAssist.Hint="Выберите аккаунт"
                      DisplayMemberPath="Value"
                      SelectedValuePath="Key"
                      Margin="5"/>
            <Button x:Name="AddButton" 
                    Content="Добавить сотрудника" 
                    Click="AddButton_Click" 
                    Margin="5"/>

            <TextBlock Text="Редактировать/Удалить сотрудника:"
                       Margin="5" 
                       FontWeight="Bold" 
                       Foreground="Gray"/>
            <TextBox x:Name="IDbox" 
                     materialDesign:HintAssist.Hint="ID сотрудника" 
                     Margin="5"/>
            <TextBox x:Name="EditFirstnameBox" 
                     materialDesign:HintAssist.Hint="Новое имя" 
                     Margin="5"/>
            <TextBox x:Name="EditSurnameBox" 
                     materialDesign:HintAssist.Hint="Новая фамилия" 
                     Margin="5"/>
            <TextBox x:Name="EditPatronymicBox" 
                     materialDesign:HintAssist.Hint="Новое отчество" 
                     Margin="5"/>
            <TextBox x:Name="EditPostBox" 
                     materialDesign:HintAssist.Hint="Новая должность" 
                     Margin="5"/>
            <ComboBox x:Name="EditAccountComboBox" 
                      materialDesign:HintAssist.Hint="Выберите новый аккаунт"
                      DisplayMemberPath="Value"
                      SelectedValuePath="Key"
                      Margin="5"/>
            <Button x:Name="EditButton" 
                    Content="Изменить" 
                    Click="EditButton_Click" 
                    Margin="5"/>
            <Button x:Name="DelButton" 
                    Content="Удалить" 
                    Click="DelButton_Click" 
                    Margin="5"/>
        </StackPanel>
    </Grid>
</Page>