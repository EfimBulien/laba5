<Window x:Class="laba5.InputWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:laba5"
        mc:Ignorable="d"
        Title="Ввод суммы оплаты" Height="450" Width="800" 
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Label x:Name="label" Grid.Row="0" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,0,0,10" FontSize="14"/>

        <TextBox x:Name="inputBox" Grid.Row="1" Height="30" FontSize="14" PreviewTextInput="inputBox_PreviewTextInput"/>

        <StackPanel Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Bottom" Orientation="Horizontal" Margin="0,20,0,0">
            <Button x:Name="ok" Content="OK" Width="75" Height="30" Margin="5" Click="ok_Click" IsDefault="True"/>
            <Button x:Name="cancel" Content="Отмена" Width="75" Height="30" Margin="5" Click="cancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>