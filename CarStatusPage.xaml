<Page x:Class="laba5.CarStatusPage"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:laba5"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CarStatusPage">
    <Grid>
        <StackPanel VerticalAlignment="Bottom">
            <TextBlock Text="Добавить статус:" 
                       Margin="5" 
                       FontWeight="Bold"
                       Foreground="Gray"/>
            <TextBox x:Name="StatusBox" 
                     materialDesign:HintAssist.Hint="Статус машины" 
                     Margin="5"/>
            <Button x:Name="AddButton" 
                    Content="Добавить статус" 
                    Click="AddButton_Click" 
                    Margin="5"/>
            
            <TextBlock Text="Редактировать/Удалить статус:"
                       Margin="5" 
                       FontWeight="Bold" 
                       Foreground="Gray"/>
            <TextBox x:Name="IDbox" 
                     materialDesign:HintAssist.Hint="ID статуса" 
                     Margin="5"/>
            <TextBox x:Name="EditStatusBox" 
                     materialDesign:HintAssist.Hint="Новый статус" 
                     Margin="5"/>
            <Button x:Name="EditButton" 
                    Content="Изменить" 
                    Click="EditButton_Click" 
                    Margin="5"/>
            <Button x:Name="DelButton" 
                    Content="Удалить" 
                    Click="DelButton_Click" 
                    Margin="5"/>
        </StackPanel>
    </Grid>
</Page>
