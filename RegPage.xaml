<Page x:Class="laba5.RegPage"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:laba5"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="RegPage">

    <Grid>
        <StackPanel VerticalAlignment="Bottom">
            <TextBlock Text="Добавить пользователя:" 
                       Margin="5" 
                       FontWeight="Bold"
                       Foreground="Gray"/>
            <TextBox x:Name="LoginBox"
                     materialDesign:HintAssist.Hint="Логин
                     " Margin="5"/>
            <TextBox x:Name="PasswordBox"
                     materialDesign:HintAssist.Hint="Пароль" 
                     Margin="5"/>
            <ComboBox x:Name="RoleBox" 
                      materialDesign:HintAssist.Hint="Роль"
                      Margin="5" VerticalAlignment="Center"
                      Height="40">
                <ComboBoxItem>Админ</ComboBoxItem>
                <ComboBoxItem>Пользователь</ComboBoxItem>
            </ComboBox>
            <Button x:Name="RegButton" 
                    Content="Зарегестрировать" 
                    VerticalAlignment="Bottom" 
                    Click="RegButton_Click"
                    Margin="5"/>
            
            <TextBlock Text="Редактировать/Удалить пользователя:"
                       Margin="5" 
                       FontWeight="Bold" 
                       Foreground="Gray"/>
            <TextBox x:Name="SearchLoginBox" 
                     materialDesign:HintAssist.Hint="Введите логин для поиска" 
                     Margin="5"/>
            <TextBox x:Name="EditLoginBox"
                     materialDesign:HintAssist.Hint="Новый логин"
                     Margin="5"/>
            <TextBox x:Name="EditPasswordBox" 
                     materialDesign:HintAssist.Hint="Новый пароль" 
                     Margin="5"/>
            <Button x:Name="EditButton" Content="Обновить"
                    VerticalAlignment="Bottom" 
                    Click="EditButton_Click"
                    Margin="5"/>
            <Button x:Name="DeleteButton" Content="Удалить"
                    VerticalAlignment="Bottom"
                    Click="DeleteButton_Click"
                    Margin="5"/>
        </StackPanel>
    </Grid>
</Page>
